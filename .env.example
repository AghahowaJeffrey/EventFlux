# ── Postgres ──────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=eventflux
POSTGRES_USER=eventflux
POSTGRES_PASSWORD=eventflux_secret

# ── Redis ─────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_STREAM_KEY=events:raw
REDIS_CONSUMER_GROUP=batch_workers

# ── Ingestion API ─────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
MAX_BATCH_SIZE=5000

# ── Batch Worker ──────────────────────────────────
WORKER_BATCH_SIZE=500
WORKER_FLUSH_INTERVAL_S=2
WORKER_MAX_BLOCK_MS=2000

# ── Aggregation ───────────────────────────────────
AGGREGATION_INTERVAL_S=60
